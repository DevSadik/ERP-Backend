# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/ERP?retryWrites=true&w=majority
DB_NAME=ERP

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=15d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Admin setup (set a strong secret; without it /setup-admin is disabled) ────
ADMIN_SETUP_KEY=set-a-strong-secret-here

# ── SMS (BulkSMSBD) ───────────────────────────────────────────────────────────
BULKSMS_API_KEY=your_bulksmsbd_api_key
BULKSMS_SENDER_ID=your_approved_sender_id
SMS_TEST_MODE=false

# ── bKash Payment Gateway (PGW) ──────────────────────────────
# Get these 4 from bKash merchant onboarding (pgw-integration.bkash.com)
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_SANDBOX=true          # true = testing, false = live
BACKEND_URL=https://erp-backend-pmf0.onrender.com
